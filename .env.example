# ------------------------------------------------------------------------------
# Application Identity
# ------------------------------------------------------------------------------
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Canonical source URL for AGPL transparency. Replace this in forks.
APP_SOURCE_URL=https://github.com/LabSchool-GR/Exams
APP_VERSION=dev
APP_LICENSE=AGPL-3.0-or-later
APP_UPDATE_ENABLED=true
APP_UPDATE_MANIFEST_URL=
APP_UPDATE_GITHUB_REPOSITORY=LabSchool-GR/Exams
APP_UPDATE_TIMEOUT_SECONDS=5
APP_UPDATE_CACHE_TTL_MINUTES=30

# ------------------------------------------------------------------------------
# Localization
# ------------------------------------------------------------------------------
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ------------------------------------------------------------------------------
# Runtime and Maintenance
# ------------------------------------------------------------------------------
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# Database
# sqlite is the local default. Uncomment MySQL settings when needed.
# ------------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ------------------------------------------------------------------------------
# Session
# ------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# ------------------------------------------------------------------------------
# Queue, Cache, Broadcast, Files
# ------------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# ------------------------------------------------------------------------------
# In-memory stores
# ------------------------------------------------------------------------------
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Mail (PSD baseline)
# For Panhellenic School Network deployments keep SMTP defaults below.
# ------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_ENCRYPTION=null
MAIL_HOST=websitemail.sch.gr
MAIL_PORT=25
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="xxxxxxxx@sch.gr"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# Object storage (optional)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# Application Security Controls
# ------------------------------------------------------------------------------
SECURITY_REGISTRATION_ALLOWED_EMAIL_DOMAINS=sch.gr
SECURITY_REGISTRATION_THROTTLE=5,1
SECURITY_FEEDBACK_THROTTLE=3,10
SECURITY_PRUNE_DISPLAY_SESSIONS_AFTER_HOURS=48
SECURITY_DISPLAY_POLL_INTERVAL_MS=1500
SECURITY_CSP_ENABLED=true
SECURITY_CSP_REPORT_ONLY=false
# SECURITY_CSP_REPORT_URI=

# ------------------------------------------------------------------------------
# Bot protection (Cloudflare Turnstile)
# ------------------------------------------------------------------------------
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
